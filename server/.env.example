# Copy this file to .env and fill in your values.
# go run . will load .env automatically via godotenv.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
ALLOWED_ORIGIN=http://localhost:5173

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/markdown_editor?sslmode=disable

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Leave SMTP_HOST empty to enable dev mode (OTPs printed to stdout instead).
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=you@yourdomain.com
SMTP_PASS=yourpassword
SMTP_FROM=noreply@yourdomain.com

# Set to "true" to skip SMTP entirely and log OTPs to stdout.
EMAIL_DEV_MODE=true

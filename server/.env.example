# Copy this file to .env and fill in your values.
# go run . will load .env automatically via godotenv.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
ALLOWED_ORIGIN=http://localhost:5173

# Set to "true" ONLY when running behind a reverse proxy (nginx, Cloudflare, a
# load balancer) that sets X-Forwarded-For / X-Real-IP and strips any inbound
# copies from clients. When false, the rate limiter keys off the TCP peer
# address, which clients cannot spoof. Leaving this false while behind a proxy
# makes every request appear to come from the proxy IP (one shared rate-limit
# bucket); setting it true without a sanitising proxy lets clients forge the
# header and bypass rate limiting entirely.
TRUST_PROXY_HEADERS=false

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/markdown_editor?sslmode=disable

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Leave SMTP_HOST empty to enable dev mode (OTPs printed to stdout instead).
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=you@yourdomain.com
SMTP_PASS=yourpassword
SMTP_FROM=noreply@yourdomain.com

# Set to "true" to skip SMTP entirely and log OTPs to stdout.
EMAIL_DEV_MODE=true
